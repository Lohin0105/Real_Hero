## 10.1.6 Backend — Blood Request Controller (`controllers/requestController.mjs`)

```javascript
import Request from "../models/Request.mjs";
import Notification from "../models/Notification.mjs";
import User from "../models/User.mjs";
import DonorResponse from "../models/DonorResponse.mjs";
import RewardLog from "../models/RewardLog.mjs";
import { sendMail } from "../utils/emailNotifier.mjs";
import { classifySeverity } from "../utils/severityClassifier.mjs";
import { updateReliability } from "../utils/reliabilityManager.mjs";
import { detectFraud } from "../utils/fraudDetector.mjs";
import { getTranslation } from "../utils/translationManager.mjs";
import * as pushNotifs from "./pushNotificationController.mjs";

/**
 * POST /api/requests/create
 * Creates a blood request; triggers geo-based notifications to nearby donors.
 */
export const createRequest = async (req, res) => {
  try {
    let { name, age, phone, bloodGroup, units, hospital, description, location } = req.body;
    let uid = req.user?.uid;
    let requesterId = req.user?._id;

    if (!requesterId) return res.status(401).json({ message: "Authentication required" });

    // AI: Fraud Detection
    const fraud = await detectFraud(requesterId, 'request');
    if (fraud.isFraud) {
      return res.status(403).json({ error: "Action Blocked", reason: fraud.reason });
    }

    const payload = { uid, requesterId, name, age, phone, bloodGroup,
                      units: Number(units || 1), urgency: req.body.urgency || "normal",
                      hospital, description };

    // AI: Auto-classify urgency from description
    const aiUrgency = await classifySeverity(hospital, description);
    if (aiUrgency === 'high' && payload.urgency !== 'high') {
      payload.urgency = 'high'; // AI override
    }

    // Attach geolocation (from client or auto-geocode from hospital name)
    if (location && typeof location.lat === "number" && typeof location.lng === "number") {
      payload.location = { lat: location.lat, lng: location.lng };
      payload.locationGeo = { type: "Point", coordinates: [location.lng, location.lat] };
    } else if (hospital) {
      try {
        const q = encodeURIComponent(hospital);
        const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&q=${q}&limit=1`;
        const geocodeRes = await fetch(url, { headers: { 'User-Agent': 'Real-Hero-Backend' } });
        if (geocodeRes.ok) {
          const hits = await geocodeRes.json();
          if (hits.length > 0) {
            const latN = parseFloat(hits[0].lat);
            const lonN = parseFloat(hits[0].lon);
            if (!isNaN(latN) && !isNaN(lonN)) {
              payload.location = { lat: latN, lng: lonN };
              payload.locationGeo = { type: 'Point', coordinates: [lonN, latN] };
            }
          }
        }
      } catch (e) { console.warn('Geocode failed:', e?.message); }
    }

    const reqDoc = await Request.create(payload);

    // Notify nearby donors (within 50km) — geo-based with fallback to all users
    try {
      const [lng, lat] = payload.locationGeo?.coordinates || [];
      const hasGeo = typeof lng === 'number' && typeof lat === 'number';
      const radiusInRadians = 50000 / 6378137; // 50 km
      const excludeFilter = { $nor: [{ uid }, { _id: requesterId }] };

      let usersToNotify = [];

      if (hasGeo) {
        // Pass 1: Geo-based search
        usersToNotify = await User.find({
          ...excludeFilter,
          locationGeo: { $geoWithin: { $centerSphere: [[lng, lat], radiusInRadians] } }
        }).select("_id name email preferredLanguage").lean();
      }

      // Pass 2: Fallback — notify all registered users if no geo match
      if (usersToNotify.length === 0) {
        usersToNotify = await User.find({
          ...excludeFilter,
          email: { $exists: true, $ne: "" }
        }).select("_id name email preferredLanguage").lean();
      }

      if (usersToNotify.length > 0) {
        // Create in-app notifications
        const notifications = usersToNotify.map((u) => ({
          userId: u._id,
          title: "🩸 Urgent: Blood Donor Needed",
          body: `${name} needs ${bloodGroup} blood at ${hospital}. Can you help?`,
          meta: { requestId: reqDoc._id, bloodGroup, urgency: payload.urgency },
          createdAt: new Date(),
        }));
        await Notification.insertMany(notifications);

        // Send email notifications (fire-and-forget)
        (async () => {
          for (const u of usersToNotify) {
            if (!u.email) continue;
            const lang = u.preferredLanguage || 'en';
            await sendMail({
              to: u.email,
              subject: getTranslation(lang, 'reqSubjectNearby', { bloodGroup }),
              html: `<p>Dear ${u.name || "Donor"},</p>
                     <p><b>Blood Donation Needed</b></p>
                     <ul>
                       <li>Blood Group: ${bloodGroup}</li>
                       <li>Hospital: ${hospital}</li>
                       <li>Units: ${units || 1}</li>
                       <li>Contact: ${phone}</li>
                     </ul>
                     <p>Open the Real-Hero app to respond.</p>`
            }).catch(() => {});
          }
        })();
      }
    } catch (notifErr) {
      console.error("Notification error:", notifErr);
    }

    // Push Notifications
    pushNotifs.notifyMatchingDonors(reqDoc).catch(e => console.error("Push notify error:", e));

    return res.json({ ok: true, requestId: reqDoc._id, request: reqDoc });
  } catch (err) {
    console.error("createRequest:", err);
    return res.status(500).json({ error: "Failed to create request" });
  }
};

/**
 * GET /api/requests/recent
 * Returns open requests ordered by proximity (if donor location is known) or recency.
 */
export const getRecentRequests = async (req, res) => {
  try {
    const limit = Number(req.query.limit || 100);
    const donorLat = parseFloat(req.query.lat);
    const donorLng = parseFloat(req.query.lng);
    const { urgency, hospital, sortBy } = req.query;

    const query = { status: { $in: ['open', 'primary_assigned', 'backup_assigned'] } };
    if (urgency && urgency !== 'all') query.urgency = urgency;
    if (hospital) query.hospital = { $regex: hospital, $options: 'i' };

    const hasDonorCoords = !isNaN(donorLat) && !isNaN(donorLng);

    if (hasDonorCoords) {
      // Use MongoDB $geoNear aggregation for distance-sorted results
      const pipeline = [
        {
          $geoNear: {
            near: { type: 'Point', coordinates: [donorLng, donorLat] },
            distanceField: 'dist.calculated',
            query,
            spherical: true,
          },
        },
        { $limit: limit },
        {
          $project: {
            name: 1, phone: 1, bloodGroup: 1, units: 1, hospital: 1,
            description: 1, urgency: 1, createdAt: 1, status: 1,
            location: 1, locationGeo: 1, requesterId: 1,
            distanceMeters: '$dist.calculated',
          },
        },
      ];
      const docs = await Request.aggregate(pipeline);
      return res.json(docs.map(d => ({
        ...d,
        distanceKm: d.distanceMeters != null ? (d.distanceMeters / 1000).toFixed(1) : null,
      })));
    }

    const docs = await Request.find(query).sort({ createdAt: -1 }).limit(limit).lean();
    return res.json(docs);
  } catch (err) {
    console.error('getRecentRequests:', err);
    return res.status(500).json({ error: 'Failed to fetch requests' });
  }
};

/**
 * POST /api/requests/claim/:id
 * Assigns the authenticated user as primary or backup donor.
 */
export const claimRequest = async (req, res) => {
  try {
    const { id } = req.params;
    const user = req.user;
    if (!user) return res.status(401).json({ error: "User not identified" });

    // AI: Fraud detection
    const fraud = await detectFraud(user._id, 'claim');
    if (fraud.isFraud) return res.status(403).json({ error: "Action Blocked", reason: fraud.reason });

    const request = await Request.findById(id);
    if (!request) return res.status(404).json({ error: "Request not found" });
    if (request.status === 'fulfilled' || request.status === 'cancelled') {
      return res.status(400).json({ error: "Request is already closed" });
    }

    const existing = await DonorResponse.findOne({ requestId: id, donorId: user._id });
    if (existing) return res.status(400).json({ error: "You have already responded to this request" });

    if (request.requesterId?.toString() === user._id.toString()) {
      return res.status(400).json({ error: "You cannot donate to your own request." });
    }

    let role = 'backup';
    let message = "You are a Backup Donor. Standby!";

    if (request.status === 'open' || !request.primaryDonor?.donorId) {
      role = 'primary';
      request.status = 'primary_assigned';
      request.primaryDonor = { donorId: user._id, acceptedAt: new Date(), arrived: false };
      message = "You are the Primary Donor! Please arrive within 2 hours.";
    } else {
      if (request.status === 'primary_assigned') request.status = 'backup_assigned';
      request.backupDonors.push({ donorId: user._id, acceptedAt: new Date(), promoted: false });
    }

    await request.save();
    await DonorResponse.create({ requestId: id, donorId: user._id, role, status: 'active', hospital: request.hospital });

    // Notify donor via email with requester details + Google Maps link
    if (user.email) {
      const reqLat = request.location?.lat;
      const reqLng = request.location?.lng;
      const mapsLink = (reqLat && reqLng)
        ? `https://www.google.com/maps/dir/?api=1&destination=${reqLat},${reqLng}`
        : null;

      sendMail({
        to: user.email,
        subject: role === 'primary' ? 'Real-Hero: You are the Primary Donor!' : 'Real-Hero: You are a Backup Donor',
        html: `<p>Hello <strong>${user.name}</strong>,</p>
               <p>You are assigned as <strong>${role === 'primary' ? 'Primary Donor' : 'Backup Donor'}</strong>.</p>
               <h3>Requester Details</h3>
               <p>Name: ${request.name}</p>
               <p>Blood Group: ${request.bloodGroup}</p>
               <p>Phone: ${request.phone}</p>
               <p>Hospital: ${request.hospital}</p>
               ${mapsLink ? `<a href="${mapsLink}">Navigate to Hospital</a>` : ''}
               <p>Thank you for being a Real Hero!</p>`
      }).catch(console.error);
    }

    return res.json({ ok: true, role, message });
  } catch (err) {
    console.error("claimRequest:", err);
    return res.status(500).json({ error: "Failed to claim request: " + err.message });
  }
};
```

