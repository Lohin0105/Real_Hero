## 10.1.8 Backend — MediBot AI Controller (`controllers/medibotController.mjs`)

```javascript
import Groq from "groq-sdk";
import ChatSession from '../models/ChatSession.mjs';

const groq = new Groq({ apiKey: process.env.GROQ_API_KEY });

const SYSTEM_PROMPT = `You are MediBot, an advanced AI Medical Assistant for the
'Real-Hero' Blood Donation Platform.

YOUR RESPONSIBILITIES:
1. Expert Guidance: Answer questions about blood donation eligibility, process, and care.
2. Multilingual Support: Detect the language and reply in the SAME language.
3. Platform Guide: Help users navigate the Real-Hero app.
4. Medical Document Analysis: Analyze prescriptions, X-rays, lab reports, and medicine images.

TONE: Be empathetic, professional, and encouraging.`;

const toImageUrl = (image) =>
  image.startsWith("data:") ? image : `data:image/jpeg;base64,${image}`;

/** Auto-detect medical document type from image */
async function detectDocumentType(image) {
  const result = await groq.chat.completions.create({
    model: "meta-llama/llama-4-scout-17b-16e-instruct",
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: toImageUrl(image) } },
        { type: "text", text: `Classify this medical image as exactly ONE of:
          "prescription", "xray", "report", "medicine", or "other".
          Reply with ONLY one word.` }
      ]
    }],
    max_tokens: 10, temperature: 0.1
  });
  const detected = (result.choices[0]?.message?.content || "").trim().toLowerCase();
  return ["prescription", "xray", "report", "medicine"].includes(detected) ? detected : "other";
}

/** Analyze prescription image using two-stage Groq AI pipeline */
async function analyzePrescription(image, userNote) {
  // Stage 1: Vision model extracts raw text
  const visionResult = await groq.chat.completions.create({
    model: "meta-llama/llama-4-scout-17b-16e-instruct",
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: toImageUrl(image) } },
        { type: "text", text: `Read all text in this prescription: doctor name, clinic,
          patient name, date, each medicine name, dosage, frequency, duration, instructions.
          ${userNote ? `User note: "${userNote}"` : ''}` }
      ]
    }],
    max_tokens: 800, temperature: 0.1
  });
  const rawPrescription = visionResult.choices[0]?.message?.content || "";

  // Stage 2: Language model formats into structured markdown
  const summaryResult = await groq.chat.completions.create({
    model: "llama-3.3-70b-versatile",
    messages: [{
      role: "user",
      content: `Format this prescription data as structured markdown with sections:
        ## 📋 Prescription Summary
        ### 👨‍⚕️ Doctor & Clinic
        ### 👤 Patient Details
        ### 💊 Prescribed Medicines (Name | Dosage | Frequency | Duration)
        ### 📌 Instructions & Notes
        ### ⚠️ Important Reminders
        Raw Data: ${rawPrescription}
        End with disclaimer about consulting the doctor.`
    }],
    max_tokens: 1500, temperature: 0.3
  });
  return summaryResult.choices[0]?.message?.content || "Could not analyze the prescription.";
}

/** Analyze X-Ray / MRI / CT scan */
async function analyzeXRay(image, userNote) {
  const visionResult = await groq.chat.completions.create({
    model: "meta-llama/llama-4-scout-17b-16e-instruct",
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: toImageUrl(image) } },
        { type: "text", text: `Analyze this radiology scan: body region, scan type,
          anatomical structures, any abnormalities, overall impression.
          ${userNote ? `User question: "${userNote}"` : ''}` }
      ]
    }],
    max_tokens: 800, temperature: 0.2
  });
  const rawFindings = visionResult.choices[0]?.message?.content || "";

  const summaryResult = await groq.chat.completions.create({
    model: "llama-3.3-70b-versatile",
    messages: [{
      role: "user",
      content: `Format as patient-friendly radiology report:
        ## 🫁 Radiology Scan Analysis
        ### 📸 Scan Information
        ### 🔬 Observations & Findings
        ### 🚨 Potential Concerns
        ### 📊 Overall Impression
        ### ✅ Recommended Next Steps
        Findings: ${rawFindings}
        End with AI disclaimer.`
    }],
    max_tokens: 1500, temperature: 0.3
  });
  return summaryResult.choices[0]?.message?.content;
}

/** Analyze Lab Reports */
async function analyzeReport(image, userNote) {
  const visionResult = await groq.chat.completions.create({
    model: "meta-llama/llama-4-scout-17b-16e-instruct",
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: toImageUrl(image) } },
        { type: "text", text: `Extract all lab test values: test name, patient value,
          unit, reference range. Also patient name, age, date, lab name.
          ${userNote ? `User question: "${userNote}"` : ''}` }
      ]
    }],
    max_tokens: 800, temperature: 0.1
  });
  const rawReport = visionResult.choices[0]?.message?.content || "";

  const summaryResult = await groq.chat.completions.create({
    model: "llama-3.3-70b-versatile",
    messages: [{
      role: "user",
      content: `Format as lab report analysis:
        ## 🧪 Lab Report Analysis
        ### 👤 Patient & Lab Info
        ### 📊 Test Results (table with Status: ✅ Normal, 🔴 HIGH, 🔵 LOW)
        ### 🚨 Abnormal Values — Explained
        ### ✅ Normal Values
        ### 📌 Overall Summary
        ### 🏥 Recommended Actions
        Data: ${rawReport}`
    }],
    max_tokens: 2000, temperature: 0.3
  });
  return summaryResult.choices[0]?.message?.content;
}

/** Main Chat Handler — routes to image analyzers or text conversation */
export const chatWithMediBot = async (req, res) => {
  try {
    const { sessionId, message, image, imageType } = req.body;
    const userId = req.user._id;

    // Load or create chat session
    let session = sessionId
      ? await ChatSession.findOne({ _id: sessionId, user: userId })
      : null;

    if (!session) {
      const title = message
        ? (message.length > 30 ? message.substring(0, 30) + '...' : message)
        : 'Medical Image Analysis';
      session = new ChatSession({ user: userId, title, messages: [] });
    }

    const userMsgContent = message || (image ? "[Medical image uploaded]" : "");
    session.messages.push({ role: "user", content: userMsgContent, ...(image && { image }) });

    let replyContent = "";

    if (image) {
      // Auto-detect or use provided image type
      let docType = imageType === "auto" || !imageType
        ? await detectDocumentType(image)
        : imageType;

      switch (docType) {
        case "prescription": replyContent = await analyzePrescription(image, message); break;
        case "xray":         replyContent = await analyzeXRay(image, message); break;
        case "report":       replyContent = await analyzeReport(image, message); break;
        default:
          replyContent = "I could not identify this medical document type. Please upload a clearer image.";
      }
    } else {
      // Text conversation with session history (last 10 messages for context)
      const recentMessages = session.messages.slice(-10).map(msg => ({
        role: msg.role === 'user' ? 'user' : 'assistant',
        content: msg.content || ""
      }));

      const completion = await groq.chat.completions.create({
        model: "llama-3.3-70b-versatile",
        messages: [{ role: "system", content: SYSTEM_PROMPT }, ...recentMessages],
        max_tokens: 1500,
        temperature: 0.7
      });
      replyContent = completion.choices[0]?.message?.content || "Please try again.";
    }

    session.messages.push({ role: "assistant", content: replyContent });
    await session.save();

    res.status(200).json({ reply: replyContent, session });
  } catch (error) {
    console.error("MediBot Error:", error);
    res.status(500).json({ error: "MediBot is thinking too hard!", details: error.message });
  }
};
```

